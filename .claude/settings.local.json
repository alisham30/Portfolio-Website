{
  "permissions": {
    "allow": [
      "PowerShell(npm install *)",
      "PowerShell($env:NODE_ENV='development'; Start-Process -FilePath \"npm\" -ArgumentList \"run\",\"dev\" -NoNewWindow -PassThru -RedirectStandardOutput \"dev.out.log\" -RedirectStandardError \"dev.err.log\" | Select-Object Id)",
      "PowerShell(npm run *)",
      "PowerShell(Copy-Item *)"
    ]
  }
}
